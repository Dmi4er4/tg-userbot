TG_API_ID=
TG_API_HASH=
# Run 'python -m src_py login' to generate
TG_SESSION=

# Optional: channel ID for saved/deleted messages (default: Saved Messages)
USERBOT_CHANNEL_ID=

GROQ_API_KEY=

YANDEX_MUSIC_TOKEN=

ELIZA_BOT_USERNAME=

# Diary dead-hand module (DO NOT enable on forks/secondary deploys —
# only the original owner should set DIARY_ENABLED=true)
DIARY_ENABLED=false
# Pre-resolved peer id of the taak release destination. Required when
# DIARY_ENABLED=true. Verify on the server before flipping the switch.
DIARY_TAAK_PEER_ID=
# Default 30 days (2592000s). Lower for end-to-end testing.
DIARY_TIMER_DURATION_SECONDS=2592000

# ntfy reminders (optional)
NTFY_URL=
NTFY_TOPIC=reminders-username
NTFY_USER=username
NTFY_PASS=password
